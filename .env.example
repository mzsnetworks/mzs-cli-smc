# SMC Image Generator (AI hero images) — OPTIONAL.
# Only needed for the text-free hero-image tier (n8n → image model → public URL).
# Carousels and infographics need NONE of this; they render locally.
#
# Copy to .env (which is gitignored) and fill in your own values.
# Never commit .env. Never paste these into chat.

SMC_IMAGE_GEN_URL=https://your-n8n-host.example.com/webhook/your-path
SMC_IMAGE_GEN_HEADER=x-your-auth-header
SMC_IMAGE_GEN_TOKEN=replace-with-your-secret-token
