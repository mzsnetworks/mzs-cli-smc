.DS_Store

# Track all of .claude (commands, skills, agents, etc. — this project's interface),
# except machine-local state and secrets.
.claude/settings.local.json

# Secrets — never commit
.env

# Scratch / render temp
.build/
**/.carousel-html/

# Graphics — never store on GitHub (kept locally + hosted on Zipline/Blotato).
# Specs (carousel.json / *-spec.md) stay tracked so any image is regenerable.
*.png
*.jpg
*.jpeg
*.gif
*.webp
