.DS_Store

# Ignore local Claude Code state, but track shared commands and skills —
# they are part of this project's interface.
.claude/*
!.claude/commands/
!.claude/skills/
.claude/settings.local.json

# Secrets — never commit
.env

# Scratch / render temp
.build/
**/.carousel-html/

# Graphics — never store on GitHub (kept locally + hosted on Zipline/Blotato).
# Specs (carousel.json / *-spec.md) stay tracked so any image is regenerable.
*.png
*.jpg
*.jpeg
*.gif
*.webp
